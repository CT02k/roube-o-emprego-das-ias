generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PromptStatus {
  pending
  in_progress
  responded
}

enum ResponseType {
  text
  image
}

enum ReportTargetType {
  prompt
  response
}

enum ReportReason {
  spam
  harassment
  hateful
  sexual
  violence
  other
}

enum ReportStatus {
  open
  dismissed
  actioned
}

model Prompt {
  id                 String         @id @default(cuid())
  text               String
  status             PromptStatus   @default(pending)
  requesterSessionId String
  claimedBySessionId String?
  claimedAt          DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  response           PromptResponse?
  reports            Report[]

  @@index([requesterSessionId, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Asc)])
}

model PromptResponse {
  id                 String               @id @default(cuid())
  promptId           String               @unique
  type               ResponseType
  text               String?
  imageDataUrl       String?
  responderSessionId String
  upvotesCount       Int                  @default(0)
  createdAt          DateTime             @default(now())
  prompt             Prompt               @relation(fields: [promptId], references: [id], onDelete: Cascade)
  votes              PromptResponseVote[]
  reports            Report[]
}

model PromptResponseVote {
  id         String         @id @default(cuid())
  responseId String
  sessionId  String
  createdAt  DateTime       @default(now())
  response   PromptResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)

  @@unique([responseId, sessionId])
  @@index([responseId])
  @@index([createdAt(sort: Desc)])
}

model Report {
  id                  String           @id @default(cuid())
  targetType          ReportTargetType
  targetId            String
  reporterSessionId   String
  reason              ReportReason
  details             String?
  status              ReportStatus     @default(open)
  promptId            String?
  responseId          String?
  snapshotPromptText  String?
  snapshotResponseText String?
  snapshotResponseType ResponseType?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  reviewedAt          DateTime?
  reviewedBySessionId String?
  prompt              Prompt?          @relation(fields: [promptId], references: [id], onDelete: SetNull)
  response            PromptResponse?  @relation(fields: [responseId], references: [id], onDelete: SetNull)
  reporterIdentity    SessionIdentity  @relation(fields: [reporterSessionId], references: [sessionId])

  @@unique([reporterSessionId, targetType, targetId])
  @@index([status, createdAt(sort: Desc)])
  @@index([targetType, targetId])
  @@index([promptId])
  @@index([responseId])
}

model SessionIdentity {
  sessionId String   @id
  ipHash    String?
  ipSource  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  lastSeenAt DateTime @default(now())
  lastIpAt  DateTime?
  reports   Report[]

  @@index([ipHash])
  @@index([lastSeenAt(sort: Desc)])
}
